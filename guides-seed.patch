+const CITY = { city: "London", cityState: "England", country: "United Kingdom" };
+
+export default [
+  {
+    ...CITY,
+    title: "Historic London Pubs Worth Crossing Town For",
+    topic: "Bars and Clubs",
+    description:
+      "London's best pubs are time machines with beer engines. These six have centuries of history, literary ghosts and proper cask ale — and every one of them is still a genuinely good place to drink, not a museum piece.",
+    sections: [
+      {
+        rank: 1,
+        title: "Ye Olde Cheshire Cheese — Fleet Street",
+        description:
+          "Rebuilt in 1667 right after the Great Fire, this warren of dark rooms, sawdusted floors and coal fires hosted Dickens (he name-checked it in A Tale of Two Cities), Mark Twain and Sir Arthur Conan Doyle. Head down into the cellar bars, which feel medieval because parts of them are. Samuel Smith's runs it, so the beer is cheap by London standards. Easily combined with St Paul's Cathedral, ten minutes' walk away.",
+      },
+      {
+        rank: 2,
+        title: "The Lamb & Flag — Covent Garden",
+        description:
+          "Tucked up an easy-to-miss alley off Garrick Street, licensed since the early 1600s and once nicknamed 'The Bucket of Blood' for the bare-knuckle fights upstairs. Dickens drank here too (he drank everywhere). It's tiny and floods with after-work drinkers spilling into the alley — that standing-in-the-lane crowd IS the experience. Come at 3 p.m. on a weekday to actually get a seat by the fire.",
+      },
+      {
+        rank: 3,
+        title: "The George Inn — Borough",
+        description:
+          "London's last surviving galleried coaching inn, dating to 1677, now owned by the National Trust. Shakespeare's Globe was around the corner and Dickens mentioned the George in Little Dorrit. The cobbled courtyard under the wooden galleries is one of the great outdoor drinking spots in the city, two minutes from Borough Market — do the market for lunch, the George for the pint after.",
+      },
+      {
+        rank: 4,
+        title: "The Spaniards Inn — Hampstead Heath",
+        description:
+          "A 1585 tollhouse pub on the edge of Hampstead Heath, wrapped in highwayman legend (Dick Turpin's father supposedly kept it) and literary fact: Keats reportedly wrote Ode to a Nightingale in its garden, and the pub appears in Dracula and The Pickwick Papers. The big garden is heaving on sunny weekends. Do it right: a long walk across the Heath to Kenwood House, then a roast and a pint here. One of London's perfect days.",
+      },
+      {
+        rank: 5,
+        title: "The Churchill Arms — Kensington",
+        description:
+          "The most photographed pub in London — the entire façade disappears under flowers in summer and thousands of Christmas lights in December. Inside it's a shrine of Churchill memorabilia, brass pots and butterflies, and the back conservatory has served surprisingly good, cheap Thai food since the 1980s, long before that was a pub thing. A Fuller's pub, so the London Pride is well kept. Expect a crowd; it's worth it.",
+      },
+      {
+        rank: 6,
+        title: "The Mayflower — Rotherhithe",
+        description:
+          "On the Thames at the exact mooring point from which the Mayflower set sail for America in 1620 — descendants of the Pilgrims can sign the visitors' book. It's a snug, candlelit riverside pub with a small deck hanging over the water at high tide. The Sunday roast is strong and the walk along the Thames Path from Tower Bridge is the right way to arrive. Far enough from the center that it stays local.",
+      },
+    ],
+  },
+  {
+    ...CITY,
+    title: "Live Music in London: The Rooms That Matter",
+    topic: "Music and Bands",
+    description:
+      "Every giant plays London, but the city's soul lives in its smaller rooms — jazz basements, punk cellars and converted chapels where you're close enough to see the setlist. These are the venues with history in the walls and great bookings every week.",
+    sections: [
+      {
+        rank: 1,
+        title: "Ronnie Scott's — Soho",
+        description:
+          "Britain's most famous jazz club, open on Frith Street since 1959. Everyone has played here: Miles Davis, Nina Simone, Ella Fitzgerald — and Jimi Hendrix's final public performance happened on this stage. It's a proper supper club: table service, low lamps, two shows a night. Book ahead (weeks ahead for big names), or try Upstairs at Ronnie's for cheaper late sessions. The house band Late Late Show after midnight on weekends is one of Soho's best-value nights.",
+      },
+      {
+        rank: 2,
+        title: "100 Club — Oxford Street",
+        description:
+          "A basement at 100 Oxford Street that has hosted live music since 1942 — Glenn Miller-era swing, then trad jazz, then the legendary 1976 Punk Special where the Sex Pistols and The Clash announced a revolution. The Rolling Stones and Paul McCartney have both played 'secret' shows here. It still books punk, soul, jazz and surprise gigs in a room that holds about 350. When a band you love books the 100 Club, you go.",
+      },
+      {
+        rank: 3,
+        title: "O2 Academy Brixton — Brixton",
+        description:
+          "A 1929 art-deco theatre that became London's most loved big venue — around 5,000 capacity with a famously sloped floor, so you can see from anywhere. Bowie's Ziggy-era hometown, the Smiths' final gig, Bob Dylan residencies; every touring act treats Brixton as a statement show. Get there early for barrier, or hang back by the mixing desk for the best sound. Eat at Brixton Village's restaurants before doors.",
+      },
+      {
+        rank: 4,
+        title: "Union Chapel — Islington",
+        description:
+          "A working Victorian Gothic church that doubles as the most beautiful concert venue in London. Artists from Adele to Björk have played beneath its rose window, and the acoustics make hairs stand up — it suits singer-songwriters, folk and anything acoustic. Seating is in the original pews (bring a cushion or rent one), the bar serves in the side chapel, and the Daylight Music Saturday afternoon sessions are pay-what-you-can.",
+      },
+      {
+        rank: 5,
+        title: "KOKO — Camden",
+        description:
+          "The former Camden Palace theatre, reopened after a massive restoration — four levels of balconies wrapped around a stage that has seen Charlie Chaplin (it was a 1900 music hall), The Clash, Madonna's first UK show and Prince's secret gigs. The sightlines from the upper balconies are spectacular. Camden's whole ecosystem is around you: record shops, the Dublin Castle, Camden Market street food before the show.",
+      },
+      {
+        rank: 6,
+        title: "Jazz Café — Camden",
+        description:
+          "Don't let the name fool you — this Camden institution books jazz, but also soul, funk, hip-hop, Afrobeat and global stars in a 440-cap room with a dance floor downstairs and dinner tables on the balcony. D'Angelo, Amy Winehouse and Adele all did early or legendary shows here. The Friday/Saturday club nights after the gigs are an institution of their own. Book a balcony table if you want to eat; stand downstairs if you want to dance.",
+      },
+    ],
+  },
+  {
+    ...CITY,
+    title: "Eat London Like You Live There",
+    topic: "Food and Restaurants",
+    description:
+      "London is one of the best eating cities on the planet — if you know where locals actually queue. Bacon naans at dawn, 24-hour beigels, nose-to-tail pioneers and the pasta bar that started a movement: this is the shortlist.",
+    sections: [
+      {
+        rank: 1,
+        title: "Dishoom — King's Cross and citywide",
+        description:
+          "A loving recreation of Bombay's old Irani cafés, and the queue is justified. Breakfast is the secret weapon: the bacon naan roll with chili tomato jam and a house chai is one of London's iconic dishes. At dinner, the black daal (cooked 24 hours) and chicken ruby are non-negotiable. The King's Cross branch in a converted railway transit shed is the stunner. Reservations only for larger groups at peak — solo or pairs, go at odd hours or queue with everyone else; it moves.",
+      },
+      {
+        rank: 2,
+        title: "Borough Market — London Bridge",
+        description:
+          "A thousand years of food trading under Victorian ironwork. Skip breakfast and graze: a chorizo roll from Brindisa, raclette scraped to order at Kappacasein, oysters at Richard Haward's, a custard doughnut from Bread Ahead. Padella's handmade pasta is at the market's edge — see below. Go Wednesday–Friday before noon; Saturdays are gridlock by 11. Most stalls close around 5 p.m. and the market rests on Sundays.",
+      },
+      {
+        rank: 3,
+        title: "St. JOHN — Smithfield",
+        description:
+          "Fergus Henderson's white-walled temple of 'nose-to-tail' eating, opened 1994 in a former smokehouse, and arguably the most influential British restaurant of the past 40 years. The roast bone marrow with parsley salad is the signature — order it without thinking. Everything is stripped back: great ingredients, no garnish theatrics, brilliant wine list, warm madeleines baked to order for dessert. Book ahead; lunch is easier and the bar menu needs no reservation.",
+      },
+      {
+        rank: 4,
+        title: "Padella — Borough Market",
+        description:
+          "The pasta bar that launched a thousand imitators. Handmade pasta at almost trattoria prices: the pici cacio e pepe is the famous one, the eight-hour beef shin pappardelle is the sleeper hit. No reservations — join the virtual queue via the app early (it opens before service), then wander Borough Market until your table pings. A counter seat watching the pasta station is the best seat in the house.",
+      },
+      {
+        rank: 5,
+        title: "Beigel Bake — Brick Lane",
+        description:
+          "Open 24 hours, every day, since 1974. The salt beef beigel — hand-carved, with mustard and a pickle — at 3 a.m. is a London rite of passage, and the queue of clubbers, cabbies and police officers at that hour is the city in one room. Cash-friendly, absurdly cheap, zero seats. Pair with a Sunday morning on Brick Lane and Columbia Road Flower Market, or make it your final stop after a Shoreditch night out.",
+      },
+      {
+        rank: 6,
+        title: "The Wolseley — Piccadilly",
+        description:
+          "Grand European café dining in a 1921 marble-and-lacquer former car showroom next to The Ritz. It's the great London breakfast room: kippers, kedgeree, eggs Benedict and perhaps the city's most elegant full English, served with theatre by a brigade in long aprons. Afternoon tea here is better value than most hotel versions. Breakfast bookings are the easiest to get and the most magical time in the room.",
+      },
+    ],
+  },
+  {
+    ...CITY,
+    title: "London's Legendary Barber Shops and Grooming Rooms",
+    topic: "Barber Shops",
+    description:
+      "London invented the gentleman's grooming ritual and still does it better than anywhere — from the world's oldest barbershop to Turkish hot-towel masters. Where to get a proper wet shave, a sharp cut, or just feel like royalty for an hour.",
+    sections: [
+      {
+        rank: 1,
+        title: "Truefitt & Hill — St James's",
+        description:
+          "Established 1805 and certified by Guinness as the oldest barbershop in the world. Barbers to Churchill, Dickens and the royal household (they hold a Royal Warrant), and the St James's shop still does the full ceremony: hot towels, badger-brush lather, straight razor, and their own colognes. The traditional wet shave here is the benchmark — book ahead, arrive early, and add the haircut for the complete experience.",
+      },
+      {
+        rank: 2,
+        title: "Geo. F. Trumper — Mayfair",
+        description:
+          "The other great Victorian grooming house, founded 1875, all mahogany booths and glass cabinets of their famous shaving creams (the violet and the lime are classics to take home). Trumper's still teaches a 'shaving school' if you want to learn the straight-razor art yourself. The Curzon Street shop feels unchanged in a century — a haircut here comes with more history per square foot than most museums.",
+      },
+      {
+        rank: 3,
+        title: "Taylor of Old Bond Street — Jermyn Street",
+        description:
+          "Founded 1854 and the source of the sandalwood shaving cream that wet-shavers worldwide consider the gold standard. The Jermyn Street shop sits on London's classic menswear street — get a shave, then walk the shirtmakers and shoe shops of St James's. Less formal than Truefitt up the road, with prices to match, and the product wall is dangerous for your luggage allowance.",
+      },
+      {
+        rank: 4,
+        title: "Murdock London — Shoreditch and citywide",
+        description:
+          "The modern classic. Since 2006 Murdock has translated the old St James's ritual for a new generation — proper cut-throat shaves and sharp scissor cuts in handsome, dark-wood rooms without the stuffiness. The Shoreditch original on Old Street is the flagship mood. Their own range of colognes and beard oils has earned a cult following. Book online; weekday mornings are calmest.",
+      },
+      {
+        rank: 5,
+        title: "Ted's Grooming Room — citywide",
+        description:
+          "Turkish barbering scaled into a London institution, from the founder of Ted Baker. The 'Full Ted' is the show: cut, hot-towel shave, and the flaming-taper ear singe that sounds terrifying and feels great. Branches across central London make it the easy walk-in option when you need to look sharp before a night out, and the banter is half the value.",
+      },
+      {
+        rank: 6,
+        title: "Pall Mall Barbers — Trafalgar Square",
+        description:
+          "Trading since 1896 from a shop a minute off Trafalgar Square, and a favorite of city workers and visiting film crews alike. It's the no-nonsense end of the heritage spectrum: master barbers, quick precise work, fair prices for the postcode. Ideal when you want the history without the half-day ceremony — walk out looking like a local in 45 minutes.",
+      },
+    ],
+  },
+];
