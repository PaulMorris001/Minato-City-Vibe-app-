+const CITY = { city: "Los Angeles", cityState: "California", country: "United States" };
+
+export default [
+  {
+    ...CITY,
+    title: "The LA Taco Run: Trucks, Stands and Legends",
+    topic: "Food and Restaurants",
+    description:
+      "Los Angeles is the best taco city outside Mexico, full stop. Trompo spinning at midnight, Tijuana-style carne asada, a James Beard-winning truck — this is the run every visitor should make, with timing notes because the best tacos keep night-shift hours.",
+    sections: [
+      {
+        rank: 1,
+        title: "Leo's Tacos Truck — La Brea & Venice",
+        description:
+          "The famous al pastor trompo: a tower of adobo-marinated pork spinning by a gas-station parking lot, carved by taqueros who flick the pineapple off the top of the spit directly onto your taco mid-air. A dollar-and-change per taco, open past 2 a.m., and consistently mobbed with the entire spectrum of Los Angeles. Order al pastor 'con todo' (onion, cilantro, salsa) and eat on the hood of your car like everyone else. Multiple trucks now; the 1515 S La Brea original is the rite.",
+      },
+      {
+        rank: 2,
+        title: "Mariscos Jalisco — Boyle Heights",
+        description:
+          "The most awarded taco truck in America, parked on Olympic Blvd for decades. One order: the tacos dorados de camarón — crispy fried shrimp tacos drowned in fresh tomato salsa and avocado, a recipe from San Juan de los Lagos that chef Raúl Ortega guards like state secrets. Critics from every publication in the country have made this pilgrimage. Daytime only — it's a lunch truck. Get there before 2 p.m., order aguachile too if it's hot out.",
+      },
+      {
+        rank: 3,
+        title: "Sonoratown — Downtown",
+        description:
+          "Flour tortillas made from Sonoran wheat, stretched paper-thin and cooked to blistered perfection — the northern-Mexico style LA never had until this tiny DTLA shop arrived and started winning national 'best taco' lists. The chivichanga and the costra (cheese-crusted) carne asada taco are the moves. The mesquite-grilled beef and that tortilla together explain everything. Cheap, fast, no theater. Downtown lunch perfection before a museum or arena evening.",
+      },
+      {
+        rank: 4,
+        title: "Tacos 1986 — citywide, Tijuana style",
+        description:
+          "The Tijuana-style juggernaut that conquered LA: adobada carved off the spit, hand-pressed corn tortillas, the 'with everything' loaded with guacamole at no extra charge — TJ rules. Founders from Tijuana brought the border's late-night energy and turned it into one of the city's defining mini-chains. The downtown location runs late. Order adobada and a mulita, stand at the counter ledge, repeat across town for science.",
+      },
+      {
+        rank: 5,
+        title: "Guisados — Boyle Heights and beyond",
+        description:
+          "Tacos built on guisos — the slow-braised home-style stews of Mexican abuela kitchens — served on thick, just-pressed tortillas from the family's adjacent tortilleria heritage. The sampler plate (six mini tacos) is the correct first order: cochinita pibil, tinga, chicharrón, the fearsome 'chiles toreados' for the brave. The Boyle Heights original keeps neighborhood prices and soul. This is the daytime, sit-down counterpoint to the trompo trucks — and arguably the most LA-born taco of all.",
+      },
+      {
+        rank: 6,
+        title: "Angel's Tijuana Tacos — multiple night spots",
+        description:
+          "The trompo wars' other champion: glowing al pastor spits at pop-up stands across the city, plus handmade tortillas pressed to order — rare at street level. The adobada-to-pineapple ratio is calibrated for joy, and the green salsa has a cult. Stands materialize evenings and run deep into the night; the energy at midnight on a weekend, surrounded by half of young LA, is the city at its most alive. Cash moves fastest.",
+      },
+    ],
+  },
+  {
+    ...CITY,
+    title: "LA Bars With a Story: Tiki Temples to Dive Royalty",
+    topic: "Bars and Clubs",
+    description:
+      "LA drinking is time travel: a 1961 tiki shrine, Bukowski's dive, a 100-year-old Hollywood steakhouse bar and a '70s house party that never ended. Six rooms with real history and real pours — far from the velvet-rope circuit.",
+    sections: [
+      {
+        rank: 1,
+        title: "Tiki-Ti — Los Feliz, since 1961",
+        description:
+          "A 12-seat tiki shoebox on Sunset opened by Ray Buhen, one of the original Don the Beachcomber bartenders, and still run by his family. Nearly 100 tropical drinks; order Ray's Mistake and answer the room's call-and-response when someone orders a Blood and Sand ('Toro! Toro!'). Cash only, tiny, frequently a wait — all part of the liturgy. One of the last family-owned tiki bars in America and the most charming bar in Los Angeles, period.",
+      },
+      {
+        rank: 2,
+        title: "Musso & Frank Grill — Hollywood, since 1919",
+        description:
+          "Hollywood's oldest restaurant, where the martini arrives in a chilled glass with a sidecar carafe nested in crushed ice — widely considered the best martini in America. Chaplin had a regular booth, Fitzgerald and Faulkner drank at this bar, Tarantino filmed Once Upon a Time in Hollywood here. Sit at the bar (no reservations needed there), order the martini and the sand dabs, and tip a bartender who may have worked the room for forty years.",
+      },
+      {
+        rank: 3,
+        title: "Frolic Room — Hollywood Blvd",
+        description:
+          "The perfect dive: a 1930s room next to the Pantages Theatre with a legendary neon sign, a Hirschfeld celebrity mural, stiff cheap drinks and zero food. Bukowski's old haunt and a Black Dahlia footnote; today it's theatergoers, barflies and the occasional star avoiding the circus outside. There is nothing to 'do' here except drink well among ghosts, which is the point. One of the great neon photographs in LA after dark, too.",
+      },
+      {
+        rank: 4,
+        title: "Good Times at Davey Wayne's — Hollywood",
+        description:
+          "Enter through a refrigerator door in a fake 1970s garage sale and emerge into somebody's wood-paneled '76 house party: shag carpet, vinyl DJs, a backyard with an Airstream pouring boozy snow cones. It's a themed bar that actually sustains the bit, and weekends go off accordingly — expect a line after 9 p.m. and dress with some intent. Hollywood's most fun reliable night that doesn't involve a bottle minimum.",
+      },
+      {
+        rank: 5,
+        title: "The Spare Room — Hollywood Roosevelt",
+        description:
+          "A gaming parlor and cocktail lounge upstairs at the historic Roosevelt hotel: two vintage bowling lanes you can book by the hour, backgammon and cards at the tables, and a drink program that has collected national nominations for years. The Roosevelt itself drips Old Hollywood (the first Oscars happened downstairs in 1929). Reserve a lane, order a julep, and play like it's a more elegant century. Marilyn's old poolside suite is a floor away.",
+      },
+      {
+        rank: 6,
